APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_ENCRYPTION=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_EHLO_DOMAIN=null
MAIL_TIMEOUT=15
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Brevo SMTP example:
# MAIL_MAILER=smtp
# MAIL_SCHEME=null
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=seu-login-smtp
# MAIL_PASSWORD=sua-senha-smtp
# MAIL_FROM_ADDRESS="no-reply@seudominio.com"
# MAIL_EHLO_DOMAIN=seudominio.com
# For port 465, use MAIL_SCHEME=ssl

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

BACKUP_AUTO_ENABLED=false
BACKUP_TIME=02:30
BACKUP_PREFIX=semtur
BACKUP_INCLUDE_DATABASE=true
BACKUP_INCLUDE_STORAGE=true
BACKUP_KEEP_LOCAL_DAYS=7
BACKUP_KEEP_REMOTE_DAYS=30
BACKUP_REMOTE_ENABLED=false
BACKUP_REMOTE_DISK=backups
BACKUP_DB_CONNECTION=
BACKUP_MYSQLDUMP_BINARY=mysqldump
BACKUP_PG_DUMP_BINARY=pg_dump
BACKUP_AWS_ACCESS_KEY_ID=
BACKUP_AWS_SECRET_ACCESS_KEY=
BACKUP_AWS_DEFAULT_REGION=auto
BACKUP_AWS_BUCKET=
BACKUP_AWS_ENDPOINT=
BACKUP_AWS_USE_PATH_STYLE_ENDPOINT=true
BACKUP_AWS_URL=

SITE_TRANSLATION_PROVIDER=null
SITE_TRANSLATION_QUEUE=default
SITE_TRANSLATION_TIMEOUT=30
SITE_TRANSLATION_TARGET_LOCALES=en,es
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-4.1-mini

VITE_APP_NAME="${APP_NAME}"
